<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dojo Picks — Pixels Dojo</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
  <style>
    .tweets-hero {
      background: linear-gradient(135deg, var(--dark-bg) 0%, #16213e 60%, #0a0e1a 100%);
      border-bottom: 2px solid rgba(65,225,20,0.25);
      padding: 3rem 2rem 2.5rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .tweets-hero::before {
      content: '';
      position: absolute; top: -20%; left: -10%;
      width: 500px; height: 500px;
      background: radial-gradient(circle, rgba(65,225,20,0.06) 0%, transparent 70%);
      pointer-events: none;
    }
    .tweets-hero-eyebrow {
      font-family: 'Press Start 2P', monospace;
      font-size: 0.55rem; letter-spacing: 0.15em;
      color: var(--cyan); margin-bottom: 1rem;
    }
    .tweets-hero-title {
      font-family: 'Press Start 2P', monospace;
      font-size: clamp(1rem, 2.5vw, 1.6rem);
      color: var(--yellow); line-height: 1.6;
      margin-bottom: 0.75rem;
      text-shadow: 0 0 20px rgba(237,255,132,0.3);
    }
    .tweets-hero-sub {
      color: rgba(255,255,255,0.5);
      font-size: 0.9rem; max-width: 560px;
      margin: 0 auto 1.5rem;
      line-height: 1.7;
    }
    .competition-badge {
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: rgba(65,225,20,0.08);
      border: 1px solid rgba(65,225,20,0.3);
      color: var(--cyan); font-size: 0.78rem;
      padding: 0.4rem 1rem; border-radius: 50px;
    }

    /* ── Page body ── */
    .tweets-body {
      max-width: 1100px;
      margin: 0 auto;
      padding: 3rem 1.5rem 5rem;
    }

    /* ── Week section ── */
    .week-section {
      margin-bottom: 3rem;
    }

    .week-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      cursor: pointer;
      padding: 1rem 1.5rem;
      background: var(--card-bg);
      border: 1px solid rgba(65,225,20,0.2);
      border-radius: 12px;
      margin-bottom: 0;
      transition: all 0.2s;
      user-select: none;
    }
    .week-header:hover {
      border-color: var(--cyan);
      background: rgba(0,255,255,0.04);
    }
    .week-header.open {
      border-radius: 12px 12px 0 0;
      border-bottom-color: transparent;
    }
    .week-title {
      font-family: 'Press Start 2P', monospace;
      font-size: 0.65rem;
      color: var(--yellow);
      flex: 1;
    }
    .week-dates {
      font-size: 0.78rem;
      color: rgba(255,255,255,0.4);
    }
    .week-count {
      background: rgba(65,225,20,0.1);
      border: 1px solid rgba(65,225,20,0.25);
      color: var(--cyan);
      font-size: 0.68rem;
      padding: 0.2rem 0.6rem;
      border-radius: 50px;
    }
    .week-chevron {
      color: var(--cyan);
      font-size: 0.9rem;
      transition: transform 0.25s;
    }
    .week-header.open .week-chevron {
      transform: rotate(180deg);
    }

    /* ── Tweet grid ── */
    .week-body {
      display: none;
      background: rgba(17,24,39,0.6);
      border: 1px solid rgba(65,225,20,0.2);
      border-top: none;
      border-radius: 0 0 12px 12px;
      padding: 1.5rem;
    }
    .week-body.open { display: block; }

    /* 3-2 masonry layout */
    .tweet-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }

    /* 4th and 5th tweet span into 2-col bottom row */
    .tweet-grid .tweet-embed:nth-child(4),
    .tweet-grid .tweet-embed:nth-child(5) {
      grid-column: span 1;
    }

    /* When exactly 4 or 5, push last row to centre */
    .tweet-grid.count-4,
    .tweet-grid.count-5 {
      grid-template-columns: repeat(6, 1fr);
    }
    .tweet-grid.count-4 .tweet-embed,
    .tweet-grid.count-5 .tweet-embed {
      grid-column: span 2;
    }
    .tweet-grid.count-4 .tweet-embed:nth-child(4) {
      grid-column: 2 / span 2;
    }
    .tweet-grid.count-5 .tweet-embed:nth-child(4) { grid-column: 2 / span 2; }
    .tweet-grid.count-5 .tweet-embed:nth-child(5) { grid-column: 4 / span 2; }

    .tweet-embed {
      background: var(--card-bg);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 12px;
      overflow: hidden;
      display: flex;
      align-items: flex-start;
      justify-content: center;
      padding: 0.5rem;
      min-height: 200px;
    }

    /* Twitter embed override — make it fill the card */
    .tweet-embed .twitter-tweet {
      margin: 0 !important;
      width: 100% !important;
    }

    /* ── Featured winner badge ── */
    .tweet-winner {
      position: relative;
    }
    .tweet-winner::before {
      content: '🏆 WINNER';
      position: absolute;
      top: 0.5rem; left: 0.5rem;
      z-index: 2;
      background: var(--yellow);
      color: #000;
      font-family: 'Press Start 2P', monospace;
      font-size: 0.45rem;
      padding: 0.25rem 0.5rem;
      border-radius: 4px;
    }

    /* ── Empty state ── */
    .tweets-empty {
      text-align: center;
      padding: 3rem;
      color: rgba(255,255,255,0.3);
    }
    .tweets-empty-icon { font-size: 3rem; margin-bottom: 1rem; }

    @media (max-width: 900px) {
      .tweet-grid,
      .tweet-grid.count-4,
      .tweet-grid.count-5 {
        grid-template-columns: 1fr 1fr;
      }
      .tweet-grid .tweet-embed,
      .tweet-grid.count-4 .tweet-embed,
      .tweet-grid.count-5 .tweet-embed,
      .tweet-grid.count-4 .tweet-embed:nth-child(4),
      .tweet-grid.count-5 .tweet-embed:nth-child(4),
      .tweet-grid.count-5 .tweet-embed:nth-child(5) {
        grid-column: span 1;
      }
    }
    @media (max-width: 540px) {
      .tweet-grid,
      .tweet-grid.count-4,
      .tweet-grid.count-5 { grid-template-columns: 1fr; }
      .tweet-grid .tweet-embed,
      .tweet-grid.count-4 .tweet-embed,
      .tweet-grid.count-5 .tweet-embed,
      .tweet-grid.count-4 .tweet-embed:nth-child(4),
      .tweet-grid.count-5 .tweet-embed:nth-child(4),
      .tweet-grid.count-5 .tweet-embed:nth-child(5) {
        grid-column: span 1;
      }
      .week-title { font-size: 0.5rem; }
    }
    /* ── Winner share bar ── */
    .tweet-winner {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .winner-share-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 0.5rem;
      background: rgba(237,255,132,0.08);
      border: 1px solid rgba(237,255,132,0.3);
      border-radius: 8px;
      padding: 0.5rem 0.85rem;
      margin-bottom: 0.6rem;
      width: 100%;
      box-sizing: border-box;
    }

    .winner-share-label {
      font-family: 'Press Start 2P', monospace;
      font-size: 0.42rem;
      color: var(--yellow);
      letter-spacing: 0.05em;
    }

    .winner-share-btns {
      display: flex;
      gap: 0.4rem;
    }

    .winner-share-x,
    .winner-copy-link {
      font-size: 0.72rem;
      font-weight: 700;
      padding: 0.3rem 0.75rem;
      border-radius: 50px;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.2s;
      white-space: nowrap;
      border: none;
      font-family: inherit;
    }

    .winner-share-x {
      background: #000;
      color: #fff;
      border: 1px solid rgba(255,255,255,0.2);
    }
    .winner-share-x:hover {
      background: #1a1a1a;
      color: #fff;
      border-color: rgba(255,255,255,0.4);
    }

    .winner-copy-link {
      background: rgba(237,255,132,0.12);
      color: var(--yellow);
      border: 1px solid rgba(237,255,132,0.3);
    }
    .winner-copy-link:hover {
      background: var(--yellow);
      color: #000;
    }
    .winner-copy-link.copied {
      background: var(--cyan);
      color: #000;
      border-color: var(--cyan);
    }

    @media (max-width: 540px) {
      .winner-share-bar { flex-direction: column; align-items: flex-start; }
    }
  </style>
</head>
<body>

<%- include('partials/header') %>


<!-- Hero -->
<div class="tweets-hero">
  <div class="tweets-hero-eyebrow">✦ Community Spotlight ✦</div>
  <h1 class="tweets-hero-title">Dojo Picks</h1>
  <p class="tweets-hero-sub">Every week we feature the best Pixels community content from X. Write great stuff, win PIXELS. Mon–Fri, every week.</p>
  <span class="competition-badge">⚡ PIXELS prizes per winning post · Mon–Fri</span>
</div>

<!-- Weekly sections -->
<div class="tweets-body">

  <% if (weeks && weeks.length > 0) { %>
    <% weeks.forEach(function(week, wi) { %>
    <div class="week-section">
      <div class="week-header <%= wi === 0 ? 'open' : '' %>" onclick="toggleWeek(this)">
        <div class="week-title">Week <%= week.number %></div>
        <div class="week-dates"><%= week.dates %></div>
        <span class="week-count"><%= week.tweets.length %> pick<%= week.tweets.length !== 1 ? 's' : '' %></span>
        <span class="week-chevron">▼</span>
      </div>
      <div class="week-body <%= wi === 0 ? 'open' : '' %>">
        <% if (week.tweets && week.tweets.length > 0) { %>
          <div class="tweet-grid count-<%= week.tweets.length %>">
            <% week.tweets.forEach(function(tweet, ti) { %>
              <div class="tweet-embed <%= tweet.is_winner ? 'tweet-winner' : '' %>">
                <% if (tweet.is_winner) { %>
                  <div class="winner-share-bar">
                    <span class="winner-share-label">🏆 Winner</span>
                    <div class="winner-share-btns">
                      <a class="winner-share-x" 
                         href="https://twitter.com/intent/tweet?text=<%= encodeURIComponent('I won this week\'s Dojo Picks on @pixelsdojo! 🏆\n\nCheck it out → https://pixelsdojo.xyz/tweets') %>"
                         target="_blank" rel="noopener noreferrer">Share on X</a>
                      <button class="winner-copy-link" onclick="copyPicksLink(this)">Copy Link</button>
                    </div>
                  </div>
                <% } %>
                <blockquote class="twitter-tweet" data-theme="dark" data-dnt="true">
                  <a href="<%= tweet.tweet_url.replace('x.com','twitter.com') %>"></a>
                </blockquote>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <div class="tweets-empty">
            <div class="tweets-empty-icon">⚡</div>
            <p>No picks featured yet this week.</p>
          </div>
        <% } %>
      </div>
    </div>
    <% }); %>
  <% } else { %>
    <div class="tweets-empty" style="padding:5rem 2rem;">
      <div class="tweets-empty-icon">🐦</div>
      <p style="font-family:'Press Start 2P',monospace;font-size:0.7rem;color:var(--yellow);margin-bottom:1rem;">No picks yet</p>
      <p>Check back soon — the first Dojo Picks are coming!</p>
    </div>
  <% } %>

</div>

<%- include('partials/footer') %>

<!-- Twitter embed script -->
<script>
  window.twttr = (function(d, s, id) {
    var js, fjs = d.getElementsByTagName(s)[0],
      t = window.twttr || {};
    if (d.getElementById(id)) return t;
    js = d.createElement(s);
    js.id = id;
    js.src = "https://platform.twitter.com/widgets.js";
    fjs.parentNode.insertBefore(js, fjs);
    t._e = [];
    t.ready = function(f) { t._e.push(f); };
    return t;
  }(document, "script", "twitter-wjs"));

  // Once loaded, render any blockquotes that may have been missed
  if (window.twttr && window.twttr.ready) {
    window.twttr.ready(function(twttr) {
      twttr.widgets.load();
    });
  }
</script>

<script>
  function toggleWeek(header) {
    var body = header.nextElementSibling;
    var isOpen = header.classList.contains('open');
    header.classList.toggle('open', !isOpen);
    body.classList.toggle('open', !isOpen);
  }
</script>

<script>
  function copyPicksLink(btn) {
    var url = 'https://pixelsdojo.xyz/tweets';
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(url).then(function() {
        btn.textContent = '✓ Copied!';
        btn.classList.add('copied');
        setTimeout(function() {
          btn.textContent = 'Copy Link';
          btn.classList.remove('copied');
        }, 2500);
      });
    } else {
      // Fallback for older browsers
      var ta = document.createElement('textarea');
      ta.value = url;
      ta.style.position = 'fixed';
      ta.style.left = '-9999px';
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
      btn.textContent = '✓ Copied!';
      btn.classList.add('copied');
      setTimeout(function() {
        btn.textContent = 'Copy Link';
        btn.classList.remove('copied');
      }, 2500);
    }
  }
</script>

</body>
</html>
