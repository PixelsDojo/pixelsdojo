<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pixels Dojo Wiki - Master Pixels Online</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/chat-widget.css">
</head>
<body>
    <%- include('partials/header') %>

    <div class="main-wrapper">

      <!-- Sidebar -->
      <aside class="sidebar">
        <h4>Library</h4>
        <a href="/all-posts">📚 All Articles</a>
        <a href="/npcs-map">🗺️ NPCs & Map</a>
        <a href="/events">⚡ Events</a>
        <a href="/amas">💬 AMAs</a>
        <hr>
        <h5>Categories</h5>
        <a href="/category/startup">Start Here</a>
        <a href="/category/earn">Earn $PIXEL</a>
        <a href="/category/mastery">Mastery</a>
        <a href="/category/community">Community</a>
        <hr>
        <a href="https://forms.gle/Ea4doC8FbfnJ7DGv8" target="_blank" rel="noopener noreferrer"
           style="display:block; margin-top:0.5rem; margin-bottom:1.5rem; padding:0.7rem 1rem; background:linear-gradient(135deg,#edff84,#ffd700); color:#000; font-weight:bold; text-decoration:none; border-radius:8px; text-align:center; transition:all 0.2s;"
           onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
          💡 Suggestions or Corrections — Submit Here
        </a>
        <div class="sidebar-logo">
          <img src="/images/pixeldojo_logo_portrait.webp" alt="Pixels Dojo Logo" class="sidebar-logo-img">
        </div>
      </aside>

      <div class="main-content-area">
        
        <!-- Hero Section - SMALLER -->
        <section class="hero-full" id="top">
          <div class="hero-bg">
            <img 
              src="/images/banner_with_pixels_dojo_in_white.webp" 
              alt="Pixels Dojo Banner" 
              class="hero-bg-image"
              width="1024" height="479"
              fetchpriority="high"
              onerror="this.src='/images/defaults/default1.jpg';"
            >
            <div class="hero-overlay"></div>
          </div>

          <div class="hero-content">
            <h1 class="hero-title">PIXELS DOJO</h1>

            <div class="main-buttons">
              <a href="/category/startup" class="main-button">
                <div class="icon">🌱</div>
                <h3>Start Here</h3>
                <p>Beginner guides & first steps</p>
              </a>

              <a href="/category/earn" class="main-button">
                <div class="icon">💰</div>
                <h3>Earn $PIXEL</h3>
                <p>Strategies & mechanisms</p>
              </a>

              <a href="/category/mastery" class="main-button">
                <div class="icon">👑</div>
                <h3>Mastery</h3>
                <p>VIP • NFTs • Advanced</p>
              </a>
            </div>
          </div>
        </section>

        <!-- Search Bar -->
        <div class="search-bar-container">
          <form action="/search" method="GET" class="search-form">
            <input type="text" name="q" placeholder="Search the wiki..." required>
            <button type="submit" class="btn btn-cyan">Search</button>
          </form>
        </div>


        <!-- ── DOJO PICKS BLOCK ─────────────────────────────────── -->
        <% if (typeof thisWeekPicks !== 'undefined' && thisWeekPicks && thisWeekPicks.length > 0) { %>
        <section class="dojo-picks-block" style="margin: 2rem 0; padding: 1.5rem; background: linear-gradient(135deg, rgba(237,255,132,0.05) 0%, rgba(0,255,255,0.03) 100%); border: 1px solid rgba(237,255,132,0.2); border-radius: 16px;">
          <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.2rem; flex-wrap:wrap; gap:0.5rem;">
            <div>
              <span style="font-family:'Press Start 2P',monospace; font-size:0.55rem; color:var(--cyan); letter-spacing:0.1em; display:block; margin-bottom:0.4rem;">✦ This Week ✦</span>
              <h2 style="margin:0; color:var(--yellow); font-size:1.1rem;">🏆 Dojo Picks</h2>
            </div>
            <a href="/tweets" style="display:inline-flex; align-items:center; gap:0.4rem; padding:0.5rem 1rem; background:rgba(237,255,132,0.1); border:1px solid rgba(237,255,132,0.3); color:var(--yellow); border-radius:50px; font-size:0.78rem; text-decoration:none; transition:all 0.2s;" onmouseover="this.style.background='rgba(237,255,132,0.2)'" onmouseout="this.style.background='rgba(237,255,132,0.1)'">
              View All Picks →
            </a>
          </div>
          <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:0.75rem;">
            <% thisWeekPicks.forEach(function(pick) { %>
              <a href="<%= pick.tweet_url %>" target="_blank" rel="noopener noreferrer"
                style="display:flex; flex-direction:column; gap:0.4rem; padding:0.9rem 1rem; background:rgba(0,0,0,0.3); border:1px solid <%= pick.is_winner ? 'rgba(237,255,132,0.4)' : 'rgba(255,255,255,0.07)' %>; border-radius:10px; text-decoration:none; transition:all 0.2s; position:relative;"
                onmouseover="this.style.borderColor='var(--cyan)'; this.style.transform='translateY(-2px)'"
                onmouseout="this.style.transform='translateY(0)'">
                <% if (pick.is_winner) { %>
                  <span style="position:absolute; top:-8px; left:10px; background:var(--yellow); color:#000; font-size:0.55rem; font-weight:800; padding:0.2rem 0.5rem; border-radius:4px;">🏆 WINNER</span>
                <% } %>
                <span style="font-size:1.4rem;">🐦</span>
                <span style="color:rgba(255,255,255,0.5); font-size:0.7rem; word-break:break-all; line-height:1.4;">
                  <%= pick.tweet_url.replace('https://','').replace('www.','').substring(0,45) %>...
                </span>
                <span style="color:var(--cyan); font-size:0.72rem; margin-top:auto;">View on X →</span>
              </a>
            <% }); %>
          </div>
        </section>
        <% } %>
        <!-- ── END DOJO PICKS BLOCK ──────────────────────────────── -->

        <!-- Category Grid -->
        <section class="category-grid">
          
          <!-- Start Here -->
          <div class="category-block">
            <h2>🌱 Start Here</h2>
            <p><strong>New to Pixels?</strong> Learn the basics of TerraVilla, meet the NPCs, and get your first $PIXEL!</p>
            <ul>
              <li>🗺️ Navigate TerraVilla</li>
              <li>👥 Meet the NPCs</li>
              <li>🌾 Start farming</li>
              <li>⚡ Your first quest</li>
            </ul>
            <a href="/category/startup" class="btn btn-outline">View Guides →</a>
          </div>

          <!-- Earn $PIXEL -->
          <div class="category-block">
            <h2>💰 Earn $PIXEL</h2>
            <p><strong>Make money playing!</strong> Discover all the ways to earn $PIXEL tokens in the game.</p>
            <ul>
              <li>🌾 Farming strategies</li>
              <li>🎮 Arcade competitions</li>
              <li>📦 Shipping contracts</li>
              <li>🏆 Hearth Hall rewards</li>
            </ul>
            <a href="/category/earn" class="btn btn-outline">View Strategies →</a>
          </div>

          <!-- Mastery -->
          <div class="category-block">
            <h2>👑 Mastery</h2>
            <p><strong>Level up your game!</strong> Advanced tactics, VIP perks, NFT lands, and pro strategies.</p>
            <ul>
              <li>💎 VIP membership</li>
              <li>🏝️ NFT lands</li>
              <li>🎨 UGC creation</li>
              <li>📈 Advanced farming</li>
            </ul>
            <a href="/category/mastery" class="btn btn-outline">View Advanced →</a>
          </div>

          <!-- Recent Guides -->
          <div class="category-block recent wide-block">
            <h2>📚 Recent Guides</h2>
            <div class="recent-grid">
              <% if (recentPages && recentPages.length > 0) { %>
                <% recentPages.slice(0, 16).forEach(page => { %>
                  <a href="/pages/<%= page.slug %>" class="recent-card">
                    <% 
                      let thumbnail = '/images/placeholder.jpg';
                      try {
                        const shots = JSON.parse(page.screenshots || '[]');
                        if (shots.length > 0) thumbnail = shots[0];
                      } catch (e) {}
                    %>
                    <div class="card-image">
                      <img 
                        src="<%= thumbnail %>" 
                        alt="<%= page.title %>" 
                        loading="lazy"
                        onerror="this.src='/images/placeholder.jpg'"
                      >
                    </div>
                    <div class="card-content">
                      <h3><%= page.title %></h3>
                      <p class="snippet">
                        <%= (page.summary || page.content.substring(0, 150) + '...') %>
                      </p>
                      <small>By <%= page.author_display_name || 'Community' %></small>
                    </div>
                  </a>
                <% }) %>
              <% } else { %>
                <p class="no-content">No guides yet - be the first to contribute!</p>
              <% } %>
            </div>
            <a href="/all-posts" class="btn btn-outline">View All Guides →</a>
          </div>
        </section>

        <!-- Most Upvoted - COMPACT VERSION -->
        <section class="featured-compact">
          <h2>⭐ Most Upvoted Guide</h2>
          <% if (mostUpvoted) { %>
            <% 
              let upvotedThumb = '/images/placeholder.jpg';
              try {
                if (mostUpvoted.screenshots) {
                  const shots = typeof mostUpvoted.screenshots === 'string' 
                    ? JSON.parse(mostUpvoted.screenshots) 
                    : mostUpvoted.screenshots;
                  if (shots && shots.length > 0) upvotedThumb = shots[0];
                }
              } catch (e) {}
            %>
            <a href="/pages/<%= mostUpvoted.slug %>" class="compact-card">
              <img src="<%= upvotedThumb %>" alt="<%= mostUpvoted.title %>" class="compact-thumb" onerror="this.src='/images/placeholder.jpg'">
              <div class="compact-info">
                <h3><%= mostUpvoted.title %></h3>
                <p class="compact-meta">
                  ⭐ <%= mostUpvoted.upvotes || 0 %> upvotes &nbsp;•&nbsp; 
                  <%= new Date(mostUpvoted.created_at).toLocaleDateString() %>
                  <% if (mostUpvoted.author_display_name) { %> &nbsp;•&nbsp; By <%= mostUpvoted.author_display_name %><% } %>
                </p>
                <% if (mostUpvoted.summary || mostUpvoted.content) { %>
                  <p class="compact-snippet"><%= mostUpvoted.summary || mostUpvoted.content.replace(/<[^>]*>/g, '').substring(0, 200) %>...</p>
                <% } %>
              </div>
            </a>
          <% } else { %>
            <p class="no-content">No guides yet - start creating content!</p>
          <% } %>
        </section>

        <!-- Most Viewed - COMPACT VERSION -->
        <section class="featured-compact">
          <h2>🔥 Most Viewed Guide</h2>
          <% if (mostViewed) { %>
            <% 
              let viewedThumb = '/images/placeholder.jpg';
              try {
                if (mostViewed.screenshots) {
                  const shots = typeof mostViewed.screenshots === 'string' 
                    ? JSON.parse(mostViewed.screenshots) 
                    : mostViewed.screenshots;
                  if (shots && shots.length > 0) viewedThumb = shots[0];
                }
              } catch (e) {}
            %>
            <a href="/pages/<%= mostViewed.slug %>" class="compact-card">
              <img src="<%= viewedThumb %>" alt="<%= mostViewed.title %>" class="compact-thumb" onerror="this.src='/images/placeholder.jpg'">
              <div class="compact-info">
                <h3><%= mostViewed.title %></h3>
                <p class="compact-meta">
                  👁️ <%= mostViewed.views || 0 %> views &nbsp;•&nbsp; 
                  <%= new Date(mostViewed.created_at).toLocaleDateString() %>
                  <% if (mostViewed.author_display_name) { %> &nbsp;•&nbsp; By <%= mostViewed.author_display_name %><% } %>
                </p>
                <% if (mostViewed.summary || mostViewed.content) { %>
                  <p class="compact-snippet"><%= mostViewed.summary || mostViewed.content.replace(/<[^>]*>/g, '').substring(0, 200) %>...</p>
                <% } %>
              </div>
            </a>
          <% } else { %>
            <p class="no-content">No guides yet - your article could be first!</p>
          <% } %>
        </section>

        <!-- Quick Access - 6 BLOCKS (3x2 grid) -->
        <section class="content-section quick-access">
          <h2>⚡ Quick Access</h2>
          <div class="quick-grid">
            
            <a href="/events" class="quick-block">
              <h3>⚡ Active Events</h3>
              <p>Limited-time competitions & quests</p>
            </a>
            
            <a href="/npcs-map" class="quick-block">
              <h3>🗺️ TerraVilla Map</h3>
              <p>Complete location guide & NPCs</p>
            </a>
            
            <a href="/amas" class="quick-block">
              <h3>💬 Weekly AMAs</h3>
              <p>Developer Q&As & updates</p>
            </a>
            
            <a href="/category/community" class="quick-block">
              <h3>👥 Community</h3>
              <p>Discord, socials & resources</p>
            </a>

            <a href="https://forms.gle/6dzJP8v5JYzvgmV99" target="_blank" rel="noopener noreferrer" class="quick-block contributor-block">
              <h3>✍️ Become a Contributor</h3>
              <p>Share your knowledge • Earn recognition</p>
            </a>

            <a href="#" class="quick-block merch-block">
              <h3>🛍️ Pixels Dojo Merch</h3>
              <p>Gear up in style • Coming soon!</p>
            </a>

          </div>
        </section>

        <%- include('partials/footer') %>
      </div>
    </div>

    <script src="/js/chat-widget.js"></script>
    <script src="/js/main.js"></script>
    <%- include('partials/back-to-top') %>
</body>
</html>
