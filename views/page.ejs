<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= page.title %> | Pixels Dojo Wiki</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/chat-widget.css">
</head>
<body>
  <%- include('partials/header') %>


  <div class="main-wrapper">
    <!-- Sidebar -->
    <aside class="sidebar">
      <h4>Library</h4>
      <a href="/">🏠 All Articles</a>
      <a href="/npcs-map">🗺️ NPCs & Map</a>
      <hr>
      <h5>Categories</h5>
      <a href="/category/startup">Start Here</a>
      <a href="/category/earn">Earn $PIXEL</a>
      <a href="/category/mastery">Mastery</a>
      <a href="/category/community">Community</a>
      <hr>
      <a href="https://forms.gle/Ea4doC8FbfnJ7DGv8" target="_blank" rel="noopener noreferrer" 
         style="display:block; margin-top:0.5rem; padding:0.7rem 1rem; background:linear-gradient(135deg,#edff84,#ffd700); color:#000; font-weight:bold; text-decoration:none; border-radius:8px; text-align:center; transition:all 0.2s;"
         onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
        💡 Suggest a Topic
      </a>
    </aside>

    <!-- Main content -->
    <div class="main-content-area">
      <article class="wiki-page">
        <header class="page-header">
          <h1><%= page.title %></h1>
          <div class="page-meta">
            <!-- Safe created date -->
            <span><%= page.created_at ? new Date(page.created_at).toLocaleDateString() : 'Unknown' %></span>

            <!-- Safe updated date – only show if valid and different from created -->
            <% 
              let showUpdated = false;
              let updatedStr = '';
              if (page.updated_at) {
                try {
                  const updDate = new Date(page.updated_at);
                  if (!isNaN(updDate.getTime()) && page.updated_at !== page.created_at) {
                    showUpdated = true;
                    updatedStr = updDate.toLocaleDateString();
                  }
                } catch (e) {}
              }
            %>
            <% if (showUpdated) { %>
              <span>· Updated <%= updatedStr %></span>
            <% } %>

            <span>· <%= page.views || 0 %> views</span>
          </div>
        </header>

        <!-- Main content -->
        <div class="content-body">
          <%- page.content %>
        </div>

<!-- Author Profile Card (showing the person who wrote THIS article) -->
        <% if (page.author_id && (page.author_display_name || page.author_username)) { %>
          <div class="author-profile-card" style="margin: 2rem 0; padding: 2rem; background: linear-gradient(135deg, rgba(65,225,20,0.08) 0%, rgba(237,255,132,0.08) 100%); border-radius: 12px; border: 2px solid rgba(65,225,20,0.3); box-shadow: 0 4px 20px rgba(65,225,20,0.1);">
            
            <div style="display: flex; align-items: start; gap: 2rem; flex-wrap: wrap;">
              
              <!-- Author Avatar -->
              <img 
                src="<%= page.author_profile_image || '/images/default-avatar.png' %>" 
                alt="<%= page.author_display_name || page.author_username %>"
                style="width: 120px; height: 120px; border-radius: 50%; border: 3px solid #41e114; object-fit: cover; box-shadow: 0 4px 15px rgba(65,225,20,0.4);"
              >
              
              <!-- Author Info -->
              <div style="flex: 1; min-width: 250px;">
                <h3 style="color: var(--yellow); margin: 0 0 0.5rem 0; font-size: 1.5rem;">
                  <%= page.author_display_name || page.author_username %>
                </h3>
                
                <!-- Stats Row -->
                <div style="display: flex; gap: 2rem; margin: 0.5rem 0 1rem 0; color: #41e114; font-size: 0.9rem;">
                  <div>
                    <strong><%= page.author_post_count || 0 %></strong> <%= page.author_post_count === 1 ? 'Post' : 'Posts' %>
                  </div>
                  <% if (page.author_joined_date) { %>
                    <div>
                      Joined <%= new Date(page.author_joined_date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) %>
                    </div>
                  <% } %>
                </div>
                
                <!-- Bio -->
                <% if (page.author_bio) { %>
                  <p style="color: #ddd; margin: 1rem 0; line-height: 1.6;">
                    <%= page.author_bio %>
                  </p>
                <% } %>
                
                <!-- Social Links -->
                <% if (page.author_social_links && page.author_social_links.trim()) { %>
                  <div style="margin: 1rem 0;">
                    <strong style="color: #41e114; font-size: 0.9rem;">Connect:</strong>
                    <div style="display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 0.5rem;">
                      <% 
                        const links = page.author_social_links.split('\n').map(l => l.trim()).filter(l => l);
                        links.forEach(linkLine => {
                          const parts = linkLine.split('|').map(s => s.trim());
                          if (parts.length >= 2) {
                            const name = parts[0];
                            const url = parts[1];
                      %>
                        <a href="<%= url %>" target="_blank" rel="noopener noreferrer" 
                           style="color: var(--yellow); text-decoration: none; padding: 0.4rem 0.8rem; background: rgba(237,255,132,0.1); border: 1px solid var(--yellow); border-radius: 6px; font-size: 0.85rem; transition: all 0.2s;">
                          <%= name %>
                        </a>
                      <% 
                          }
                        });
                      %>
                    </div>
                  </div>
                <% } %>
                
                <!-- Support / Tip Info -->
                <% if (page.author_tip_address && page.author_tip_address.trim()) { %>
                  <div style="margin-top: 1.5rem; padding: 1rem; background: rgba(65,225,20,0.08); border: 1px solid rgba(65,225,20,0.3); border-radius: 8px;">
                    <p style="color: #41e114; font-weight: bold; margin: 0 0 0.6rem 0; font-size: 0.95rem;">
                      💚 Support <%= page.author_display_name || page.author_username %>
                    </p>
                    <p style="color: #ddd; font-size: 0.9rem; line-height: 1.7; white-space: pre-wrap; margin: 0 0 0.75rem 0; word-break: break-all;"><%= page.author_tip_address %></p>
                    <button onclick="copyTipInfo(this)" 
                            data-tip="<%= page.author_tip_address.replace(/\"/g, '&quot;') %>"
                            style="background: #41e114; color: #000; border: none; padding: 0.4rem 1rem; border-radius: 6px; cursor: pointer; font-size: 0.85rem; font-weight: bold;">
                      📋 Copy
                    </button>
                  </div>
                <% } %>
                
              </div>
            </div>
          </div>
        <% } %>


      <!-- Share to Social Media -->
      <div style="margin: 1.5rem 0; padding: 1rem; background: rgba(20,20,40,0.6); border: 1px solid rgba(0,255,255,0.2); border-radius: 10px;">
        <p style="color: #aaa; font-size: 0.85rem; margin: 0 0 0.75rem 0;">Share this page:</p>
        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
          <a id="shareTwitter" href="#" target="_blank" rel="noopener noreferrer" style="padding: 0.5rem 1rem; background: #1da1f2; color: white; text-decoration: none; border-radius: 6px; font-size: 0.85rem; font-weight: bold;">X / Twitter</a>
          <a id="shareFacebook" href="#" target="_blank" rel="noopener noreferrer" style="padding: 0.5rem 1rem; background: #1877f2; color: white; text-decoration: none; border-radius: 6px; font-size: 0.85rem; font-weight: bold;">Facebook</a>
          <a id="shareWhatsapp" href="#" target="_blank" rel="noopener noreferrer" style="padding: 0.5rem 1rem; background: #25d366; color: white; text-decoration: none; border-radius: 6px; font-size: 0.85rem; font-weight: bold;">WhatsApp</a>
          <button onclick="copyPageLink(this)" style="padding: 0.5rem 1rem; background: rgba(0,255,255,0.15); color: #00ffff; border: 1px solid #00ffff; border-radius: 6px; font-size: 0.85rem; font-weight: bold; cursor: pointer;">Copy Link</button>
        </div>
      </div>
      <script>
        (function() {
          var url = encodeURIComponent(window.location.href);
          var title = encodeURIComponent(document.title);
          document.getElementById("shareTwitter").href = "https://twitter.com/intent/tweet?url=" + url + "&text=" + title;
          document.getElementById("shareFacebook").href = "https://www.facebook.com/sharer/sharer.php?u=" + url;
          document.getElementById("shareWhatsapp").href = "https://wa.me/?text=" + title + "%20" + url;
        })();
        function copyPageLink(btn) {
          navigator.clipboard.writeText(window.location.href).then(function() {
            btn.textContent = "Copied!";
            setTimeout(function() { btn.textContent = "Copy Link"; }, 2000);
          });
        }
      </script>
       <!-- Like / Dislike -->
<div class="interaction-bar">
  <button class="like-btn" data-page-id="<%= page.id %>" id="likeBtn">
    👍 <span class="like-count"><%= page.upvotes || 0 %></span>
  </button>
  <button class="dislike-btn" data-page-id="<%= page.id %>" id="dislikeBtn">
    👎 <span class="dislike-count"><%= page.downvotes || 0 %></span>
  </button>
</div>
<script>
(function() {
  const pageId = '<%= page.id %>';
  const storageKey = 'voted_' + pageId;
  const likeBtn = document.getElementById('likeBtn');
  const dislikeBtn = document.getElementById('dislikeBtn');

  // Check if already voted this session
  const alreadyVoted = sessionStorage.getItem(storageKey);
  if (alreadyVoted === 'like') {
    likeBtn.style.opacity = '0.5';
    likeBtn.title = 'You already liked this';
    dislikeBtn.style.opacity = '0.5';
  } else if (alreadyVoted === 'dislike') {
    dislikeBtn.style.opacity = '0.5';
    dislikeBtn.title = 'You already disliked this';
    likeBtn.style.opacity = '0.5';
  }

  async function vote(type) {
    if (sessionStorage.getItem(storageKey)) {
      return; // Already voted, do nothing
    }
    try {
      const res = await fetch(`/pages/${pageId}/vote`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type })
      });
      const data = await res.json();
      if (data.upvotes !== undefined) {
        document.querySelector('.like-count').textContent = data.upvotes;
        document.querySelector('.dislike-count').textContent = data.downvotes;
        sessionStorage.setItem(storageKey, type);
        likeBtn.style.opacity = '0.5';
        dislikeBtn.style.opacity = '0.5';
        if (type === 'like') likeBtn.title = 'Thanks for the like!';
        else dislikeBtn.title = 'Feedback noted!';
      }
    } catch(e) {
      console.error('Vote failed:', e);
    }
  }

  likeBtn.addEventListener('click', () => vote('like'));
  dislikeBtn.addEventListener('click', () => vote('dislike'));
})();
</script>

        <!-- Comments Section -->
        <section class="comments-section" style="margin-top: 2.5rem;">
          <h3 style="color: var(--cyan); margin-bottom: 1.5rem;">
            💬 Community Discussion
            <span id="commentCount" style="font-size: 0.85rem; color: #aaa; font-weight: normal; margin-left: 0.5rem;">(<%= comments.length %>)</span>
          </h3>

          <!-- Existing comments -->
          <div id="commentsList" style="display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem;">
            <% if (comments.length === 0) { %>
              <p id="noComments" style="color: #888; font-style: italic;">No comments yet — be the first!</p>
            <% } else { %>
              <% comments.forEach(comment => { %>
                <div class="comment-item" data-comment-id="<%= comment.id %>" style="display: flex; gap: 1rem; padding: 1rem; background: rgba(0,0,0,0.3); border: 1px solid rgba(0,255,255,0.1); border-radius: 10px;">
                  <img src="<%= comment.profile_image || '/images/default-avatar.png' %>"
                       alt="<%= comment.display_name || comment.username %>"
                       onerror="this.src='/images/default-avatar.png'"
                       style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover; flex-shrink: 0; border: 2px solid rgba(0,255,255,0.3);">
                  <div style="flex: 1; min-width: 0;">
                    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.4rem;">
                      <strong style="color: var(--yellow); font-size: 0.9rem;"><%= comment.display_name || comment.username %></strong>
                      <div style="display: flex; align-items: center; gap: 0.75rem;">
                        <span style="color: #888; font-size: 0.78rem;"><%= new Date(comment.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                        <% if (user && (user.id === comment.user_id || user.is_admin)) { %>
                          <!-- note: user_id not passed directly but we handle delete on server -->
                        <% } %>
                        <% if (user) { %>
                          <button onclick="deleteComment(<%= comment.id %>, this)"
                                  data-owner="<%= comment.username %>"
                                  style="background: none; border: none; color: #ff6666; cursor: pointer; font-size: 0.75rem; padding: 0; display: <%= (user && (user.username === comment.username || user.is_admin)) ? 'inline' : 'none' %>;">
                            🗑️ Delete
                          </button>
                        <% } %>
                      </div>
                    </div>
                    <p style="color: #ddd; margin: 0; line-height: 1.6; word-break: break-word; white-space: pre-wrap;"><%= comment.content %></p>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>

          <!-- Post a comment -->
          <% if (user) { %>
            <div style="background: rgba(0,0,0,0.3); border: 1px solid rgba(0,255,255,0.2); border-radius: 10px; padding: 1.25rem;">
              <div style="display: flex; gap: 0.75rem; align-items: flex-start;">
                <img src="<%= user.profile_image || '/images/default-avatar.png' %>"
                     onerror="this.src='/images/default-avatar.png'"
                     style="width: 38px; height: 38px; border-radius: 50%; object-fit: cover; flex-shrink: 0; border: 2px solid #41e114; margin-top: 2px;">
                <div style="flex: 1;">
                  <textarea id="commentInput" placeholder="Share your thoughts..." maxlength="1000"
                    style="width: 100%; min-height: 80px; background: rgba(255,255,255,0.05); border: 1px solid rgba(0,255,255,0.3); border-radius: 8px; color: white; padding: 0.75rem; font-size: 0.95rem; resize: vertical; font-family: inherit; box-sizing: border-box;"></textarea>
                  <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 0.5rem;">
                    <span id="charCount" style="color: #888; font-size: 0.8rem;">0 / 1000</span>
                    <button id="submitComment" onclick="postComment()"
                      style="background: linear-gradient(135deg, #41e114, #00ffff); color: #000; border: none; padding: 0.5rem 1.25rem; border-radius: 8px; font-weight: bold; cursor: pointer; font-size: 0.9rem;">
                      Post Comment
                    </button>
                  </div>
                </div>
              </div>
            </div>
          <% } else { %>
            <div style="text-align: center; padding: 1.5rem; background: rgba(0,0,0,0.3); border: 1px solid rgba(0,255,255,0.15); border-radius: 10px;">
              <p style="color: #aaa; margin: 0 0 0.75rem 0;">Join the discussion!</p>
              <a href="/login" style="background: var(--cyan); color: #000; padding: 0.5rem 1.5rem; border-radius: 8px; font-weight: bold; text-decoration: none;">Log in to comment</a>
            </div>
          <% } %>
        </section>

        <script>
        (function() {
          const pageId = '<%= page.id %>';

          // Char counter
          const input = document.getElementById('commentInput');
          const charCount = document.getElementById('charCount');
          if (input) {
            input.addEventListener('input', function() {
              charCount.textContent = input.value.length + ' / 1000';
            });
          }

          window.postComment = async function() {
            const content = input.value.trim();
            if (!content) return;

            const btn = document.getElementById('submitComment');
            btn.disabled = true;
            btn.textContent = 'Posting...';

            try {
              const res = await fetch(`/pages/${pageId}/comments`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ content })
              });
              const data = await res.json();

              if (data.success && data.comment) {
                // Remove "no comments" placeholder
                const noComments = document.getElementById('noComments');
                if (noComments) noComments.remove();

                // Build comment HTML
                const c = data.comment;
                const div = document.createElement('div');
                div.className = 'comment-item';
                div.dataset.commentId = c.id;
                div.style.cssText = 'display:flex; gap:1rem; padding:1rem; background:rgba(0,0,0,0.3); border:1px solid rgba(0,255,255,0.1); border-radius:10px;';
                div.innerHTML = `
                  <img src="${c.profile_image || '/images/default-avatar.png'}"
                       onerror="this.src='/images/default-avatar.png'"
                       style="width:40px;height:40px;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid rgba(0,255,255,0.3);">
                  <div style="flex:1;min-width:0;">
                    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:0.5rem;margin-bottom:0.4rem;">
                      <strong style="color:var(--yellow);font-size:0.9rem;">${c.display_name || c.username}</strong>
                      <div style="display:flex;align-items:center;gap:0.75rem;">
                        <span style="color:#888;font-size:0.78rem;">Just now</span>
                        <button onclick="deleteComment(${c.id}, this)" style="background:none;border:none;color:#ff6666;cursor:pointer;font-size:0.75rem;padding:0;">🗑️ Delete</button>
                      </div>
                    </div>
                    <p style="color:#ddd;margin:0;line-height:1.6;word-break:break-word;white-space:pre-wrap;">${c.content.replace(/</g,'&lt;').replace(/>/g,'&gt;')}</p>
                  </div>`;

                document.getElementById('commentsList').appendChild(div);

                // Update count
                const countEl = document.getElementById('commentCount');
                const current = parseInt(countEl.textContent.replace(/\D/g,'')) || 0;
                countEl.textContent = '(' + (current + 1) + ')';

                input.value = '';
                charCount.textContent = '0 / 1000';
              } else {
                alert(data.error || 'Failed to post comment');
              }
            } catch(e) {
              console.error('Comment error:', e);
              alert('Failed to post comment');
            } finally {
              btn.disabled = false;
              btn.textContent = 'Post Comment';
            }
          };

          window.deleteComment = async function(commentId, btn) {
            if (!confirm('Delete this comment?')) return;
            try {
              const res = await fetch(`/comments/${commentId}`, { method: 'DELETE' });
              const data = await res.json();
              if (data.success) {
                const item = document.querySelector(`[data-comment-id="${commentId}"]`);
                if (item) item.remove();
                const countEl = document.getElementById('commentCount');
                const current = parseInt(countEl.textContent.replace(/\D/g,'')) || 0;
                countEl.textContent = '(' + Math.max(0, current - 1) + ')';
                if (document.querySelectorAll('.comment-item').length === 0) {
                  const list = document.getElementById('commentsList');
                  list.innerHTML = '<p id="noComments" style="color:#888;font-style:italic;">No comments yet — be the first!</p>';
                }
              } else {
                alert(data.error || 'Could not delete comment');
              }
            } catch(e) {
              alert('Failed to delete comment');
            }
          };
        })();
        </script>
      </article>

      <%- include('partials/back-to-top') %>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script src="/js/chat-widget.js"></script>
  <script src="/js/main.js"></script>
  <script>
    function copyTipInfo(btn) {
      const tip = btn.getAttribute('data-tip');
      navigator.clipboard.writeText(tip).then(() => {
        btn.innerHTML = '✅ Copied!';
        btn.style.background = '#a9fe75';
        setTimeout(() => { btn.innerHTML = '📋 Copy'; btn.style.background = '#41e114'; }, 2000);
      }).catch(() => {
        alert('Please copy manually:\n\n' + tip);
      });
    }
  </script>
</body>
</html>
