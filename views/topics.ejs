<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Articles by Topic — Pixels Dojo Wiki</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/chat-widget.css">
</head>
<body>
    <%- include('partials/header') %>

    <div class="main-wrapper">
      <aside class="sidebar">
        <h4>Library</h4>
        <a href="/all-posts">📚 All Articles</a>
        <a href="/npcs-map">🗺️ NPCs & Map</a>
        <a href="/events">⚡ Events</a>
        <a href="/amas">💬 AMAs</a>
        <hr>
        <h5>Categories</h5>
        <a href="/category/startup">Start Here</a>
        <a href="/category/earn">Earn $PIXEL</a>
        <a href="/category/mastery">Mastery</a>
        <a href="/category/community">Community</a>
        <hr>
        <h5>Jump to Topic</h5>
        <% topics.forEach(function(t) { %>
          <a href="#topic-<%= t.slug %>">
            <%= t.label %>
            <span style="float:right; font-size:0.75rem; opacity:0.6;">(<%= t.articles.length %>)</span>
          </a>
        <% }) %>
      </aside>

      <div class="main-content-area">
        <section class="content-section">
          <h2>📖 Articles by Topic</h2>
          <p style="opacity:0.7; margin-bottom:2rem;">
            Browse all guides by in-game activity. Topics showing <strong>0 articles</strong> are on our to-do list — 
            <a href="https://forms.gle/Ea4doC8FbfnJ7DGv8" target="_blank">suggest a guide</a> or 
            <a href="https://forms.gle/6dzJP8v5JYzvgmV99" target="_blank">write one yourself</a>!
          </p>

          <div class="topics-grid">
            <% topics.forEach(function(t) { %>
              <div class="topic-block" id="topic-<%= t.slug %>">
                <div class="topic-header">
                  <span class="topic-icon"><%= t.icon %></span>
                  <h3 class="topic-title"><%= t.label %></h3>
                  <span class="topic-count <%= t.articles.length === 0 ? 'count-zero' : 'count-has' %>">
                    <%= t.articles.length %> article<%= t.articles.length !== 1 ? 's' : '' %>
                  </span>
                </div>

                <% if (t.articles.length > 0) { %>
                  <ul class="topic-article-list">
                    <% t.articles.forEach(function(a) { %>
                      <li>
                        <a href="/pages/<%= a.slug %>"><%= a.title %></a>
                        <% if (a.author_display_name) { %>
                          <span class="topic-author">by <%= a.author_display_name %></span>
                        <% } %>
                      </li>
                    <% }) %>
                  </ul>
                <% } else { %>
                  <p class="topic-empty">No articles yet — this topic needs a guide! 🥷</p>
                <% } %>
              </div>
            <% }) %>
          </div>
        </section>

        <%- include('partials/footer') %>
      </div>
    </div>

    <script src="/js/chat-widget.js"></script>
    <script src="/js/main.js"></script>
    <%- include('partials/back-to-top') %>
</body>
</html>

<style>
.topics-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 1.2rem;
}

.topic-block {
  background: var(--dark-bg);
  border: 1px solid rgba(101,0,255,0.3);
  border-radius: 10px;
  padding: 1rem 1.2rem;
  transition: border-color 0.2s;
}
.topic-block:hover { border-color: rgba(65,225,20,0.4); }

.topic-header {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 0.7rem;
  flex-wrap: wrap;
}
.topic-icon { font-size: 1.2rem; }
.topic-title {
  font-size: 0.78rem !important;
  margin: 0 !important;
  color: var(--yellow);
  flex: 1;
}
.topic-count {
  font-size: 0.7rem;
  padding: 2px 8px;
  border-radius: 20px;
  font-weight: 600;
  white-space: nowrap;
}
.count-has {
  background: rgba(65,225,20,0.15);
  color: #41e114;
  border: 1px solid rgba(65,225,20,0.3);
}
.count-zero {
  background: rgba(255,255,255,0.05);
  color: rgba(255,255,255,0.35);
  border: 1px solid rgba(255,255,255,0.1);
}

.topic-article-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}
.topic-article-list li {
  display: flex;
  align-items: baseline;
  gap: 0.5rem;
  font-size: 0.85rem;
  line-height: 1.3;
}
.topic-article-list a {
  color: var(--cyan);
  transition: color 0.2s;
}
.topic-article-list a:hover { color: var(--yellow); }
.topic-author {
  font-size: 0.72rem;
  opacity: 0.5;
  white-space: nowrap;
}

.topic-empty {
  font-size: 0.8rem;
  opacity: 0.45;
  font-style: italic;
  margin: 0;
}

@media (max-width: 600px) {
  .topics-grid { grid-template-columns: 1fr; }
}
</style>
